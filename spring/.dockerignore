# ============================================================
# Spring Boot .dockerignore
# Docker 빌드 시 불필요한 파일 제외 → 빌드 속도 향상 & 이미지 크기 감소
# ============================================================

# Gradle 빌드 출력물 (Docker에서 새로 빌드함)
build/
.gradle/

# IDE 설정 파일들
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
*.swo

# Git
.git/
.gitignore
.gitattributes

# 로컬 환경 파일
.env
.env.*
*.local

# 로그 파일
*.log
logs/

# OS 생성 파일
.DS_Store
Thumbs.db

# 테스트 리포트
build/reports/
build/test-results/

# 문서
README.md
docs/
*.md

# 기타
*.bak
*.tmp
*.temp
